---
import { site } from '../data/site';
import { services } from '../data/services';
import { Icon } from 'astro-icon/components';

const year = new Date().getFullYear();
---

<footer class="relative bg-night-950 text-white mt-24 overflow-hidden">
  <div class="absolute inset-0 grid-pattern opacity-30"></div>
  <div class="absolute -top-32 right-0 w-[400px] h-[400px] rounded-full bg-brand-500/10 blur-[120px]"></div>
  <div class="absolute -bottom-32 left-0 w-[400px] h-[400px] rounded-full bg-accent-500/10 blur-[120px]"></div>

  <div class="container-x relative py-20 grid gap-12 lg:grid-cols-5 lg:gap-10">
    <div class="lg:col-span-2">
      <a href="/" class="flex items-center gap-3 mb-5 group">
        <span class="relative inline-flex items-center justify-center w-11 h-11 rounded-xl bg-gradient-to-br from-cyber-400 to-brand-600 text-white font-bold shadow-lg">
          <span class="absolute inset-0 rounded-xl bg-cyber-400/40 blur-md -z-10"></span>
          V
        </span>
        <span class="flex flex-col leading-tight">
          <span class="font-display font-bold text-lg">Versatile SOC</span>
          <span class="text-[10px] uppercase tracking-[0.18em] text-cyber-300/80">India Pvt Ltd</span>
        </span>
      </a>
      <p class="text-white/65 text-sm leading-relaxed max-w-md">
        Semiconductor, embedded and AI engineering services for the product teams shaping the next decade of intelligent hardware.
      </p>

      <div class="mt-6 flex gap-3">
        <a href={site.social.linkedin} class="w-10 h-10 inline-flex items-center justify-center rounded-full bg-white/5 border border-white/10 hover:bg-cyber-500 hover:border-cyber-400 transition" aria-label="LinkedIn">
          <Icon name="lucide:linkedin" class="w-4 h-4" />
        </a>
        <a href={site.social.twitter} class="w-10 h-10 inline-flex items-center justify-center rounded-full bg-white/5 border border-white/10 hover:bg-cyber-500 hover:border-cyber-400 transition" aria-label="Twitter / X">
          <Icon name="lucide:twitter" class="w-4 h-4" />
        </a>
        <a href={site.social.youtube} class="w-10 h-10 inline-flex items-center justify-center rounded-full bg-white/5 border border-white/10 hover:bg-cyber-500 hover:border-cyber-400 transition" aria-label="YouTube">
          <Icon name="lucide:youtube" class="w-4 h-4" />
        </a>
      </div>
    </div>

    <div>
      <h4 class="text-xs font-bold uppercase tracking-[0.22em] text-cyber-300/80 mb-5">Services</h4>
      <ul class="space-y-2.5 text-sm">
        {services.map((s) => (
          <li>
            <a href={`/services/${s.slug}`} class="text-white/65 hover:text-cyber-300 transition">{s.title}</a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h4 class="text-xs font-bold uppercase tracking-[0.22em] text-cyber-300/80 mb-5">Company</h4>
      <ul class="space-y-2.5 text-sm">
        <li><a href="/about" class="text-white/65 hover:text-cyber-300 transition">About Us</a></li>
        <li><a href="/industries" class="text-white/65 hover:text-cyber-300 transition">Industries</a></li>
        <li><a href="/contact" class="text-white/65 hover:text-cyber-300 transition">Contact</a></li>
        <li><a href="/privacy" class="text-white/65 hover:text-cyber-300 transition">Privacy Policy</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-xs font-bold uppercase tracking-[0.22em] text-cyber-300/80 mb-5">Reach Us</h4>
      <ul class="space-y-3 text-sm">
        <li class="flex items-start gap-2 text-white/65">
          <Icon name="lucide:map-pin" class="w-4 h-4 mt-0.5 text-accent-400 flex-shrink-0" />
          <span class="leading-snug">{site.address.line1}<br>{site.address.line2}<br>{site.address.line3}</span>
        </li>
        <li class="flex items-center gap-2 text-white/65">
          <Icon name="lucide:mail" class="w-4 h-4 text-accent-400" />
          <a href={`mailto:${site.email}`} class="hover:text-cyber-300 transition">{site.email}</a>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10 relative">
    <div class="container-x py-5 flex flex-col md:flex-row items-center justify-between gap-3 text-xs text-white/55">
      <p>© {year} {site.legalName}. All rights reserved.</p>
      <p>Designed and engineered in Hyderabad, India.</p>
    </div>
  </div>
</footer>
