---
import AnimatedCounter from './AnimatedCounter.astro';

// TODO[placeholder]: Replace these numbers with the company's real, audited figures before going live.
const stats = [
  { value: 450, suffix: '+', label: 'Engineers & Specialists' },
  { value: 120, suffix: '+', label: 'Successful Engagements' },
  { value: 25,  suffix: '+', label: 'Tape-outs Delivered' },
  { value: 15,  suffix: '+', label: 'Years of Combined Heritage' },
];
---

<section class="relative bg-night text-white overflow-hidden border-y border-white/5">
  <div class="absolute inset-0 grid-pattern opacity-50"></div>
  <div class="container-x relative py-16 md:py-20">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-y-10 gap-x-6">
      {stats.map((s, i) => (
        <div class="text-center md:text-left relative" data-reveal style={`--reveal-delay: ${i * 80}ms`}>
          <div class="font-display font-extrabold text-4xl md:text-6xl text-gradient-cyber leading-none">
            <AnimatedCounter value={s.value} suffix={s.suffix} />
          </div>
          <p class="mt-3 text-xs md:text-sm text-white/60 uppercase tracking-[0.18em] font-semibold">{s.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
