---
import { Icon } from 'astro-icon/components';
import CircuitBackground from './CircuitBackground.astro';

interface Props {
  title?: string;
  description?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  title = 'Have a product to build or a chip to tape out?',
  description = "Tell us what you're working on. We'll come back within one business day with a clear next step — not a generic deck.",
  primaryLabel = "Let's Talk",
  primaryHref = '/contact',
  secondaryLabel = 'Explore Services',
  secondaryHref = '/services',
} = Astro.props;
---

<section class="container-x py-20 md:py-24">
  <div class="relative overflow-hidden rounded-3xl bg-night text-white p-10 md:p-16 lg:p-20" data-reveal>
    <CircuitBackground />
    <div class="absolute inset-0 grid-pattern opacity-40"></div>
    <div class="relative max-w-3xl">
      <span class="eyebrow-dark mb-5">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-cyber-400 animate-pulse"></span>
        Let's build
      </span>
      <h2 class="font-display font-extrabold text-3xl md:text-5xl lg:text-6xl leading-[1.05] text-balance">
        {title.split(' ').slice(0, -2).join(' ')}
        <span class="text-gradient-cyber"> {title.split(' ').slice(-2).join(' ')}</span>
      </h2>
      <p class="mt-6 text-white/75 text-lg md:text-xl text-pretty">{description}</p>
      <div class="mt-9 flex flex-wrap gap-4">
        <a href={primaryHref} class="btn btn-accent">
          {primaryLabel}
          <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
        <a href={secondaryHref} class="btn btn-glass">
          {secondaryLabel}
        </a>
      </div>
    </div>
  </div>
</section>
