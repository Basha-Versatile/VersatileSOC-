---
/**
 * Animated SVG circuit-board background. Pure CSS animations (no JS).
 * Traces "draw" themselves, then loop with a slow flow. Nodes pulse.
 * Composes with surrounding gradient blobs in the hero.
 */
---

<div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
  <svg
    class="absolute inset-0 w-full h-full opacity-[0.55]"
    viewBox="0 0 1440 900"
    preserveAspectRatio="xMidYMid slice"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <linearGradient id="traceGrad" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%"  stop-color="#7ff0ff" stop-opacity="0.0"/>
        <stop offset="50%" stop-color="#38e0ff" stop-opacity="0.9"/>
        <stop offset="100%" stop-color="#5996ff" stop-opacity="0.2"/>
      </linearGradient>
      <linearGradient id="traceGradOrange" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%"  stop-color="#ffb547" stop-opacity="0.0"/>
        <stop offset="50%" stop-color="#ff8a1f" stop-opacity="0.9"/>
        <stop offset="100%" stop-color="#ff8a1f" stop-opacity="0.0"/>
      </linearGradient>
      <radialGradient id="nodeGlow" cx="50%" cy="50%" r="50%">
        <stop offset="0%"  stop-color="#7ff0ff" stop-opacity="1"/>
        <stop offset="100%" stop-color="#7ff0ff" stop-opacity="0"/>
      </radialGradient>
    </defs>

    <!-- Faint base grid -->
    <g stroke="rgba(255,255,255,0.05)" stroke-width="1">
      <path d="M0 150 L1440 150"/>
      <path d="M0 300 L1440 300"/>
      <path d="M0 450 L1440 450"/>
      <path d="M0 600 L1440 600"/>
      <path d="M0 750 L1440 750"/>
      <path d="M180 0 L180 900"/>
      <path d="M360 0 L360 900"/>
      <path d="M540 0 L540 900"/>
      <path d="M720 0 L720 900"/>
      <path d="M900 0 L900 900"/>
      <path d="M1080 0 L1080 900"/>
      <path d="M1260 0 L1260 900"/>
    </g>

    <!-- Central die / SoC silhouette -->
    <g transform="translate(960 450)">
      <!-- Outer die border -->
      <rect x="-180" y="-180" width="360" height="360" rx="14"
            fill="none" stroke="rgba(56,224,255,0.35)" stroke-width="1.5"
            class="trace trace--draw" style="--len: 1440;"/>
      <!-- Inner core -->
      <rect x="-110" y="-110" width="220" height="220" rx="10"
            fill="rgba(56,224,255,0.04)" stroke="rgba(56,224,255,0.5)" stroke-width="1"
            class="trace trace--draw" style="--len: 880; animation-delay: 0.4s;"/>
      <!-- Inner-inner core -->
      <rect x="-50" y="-50" width="100" height="100" rx="6"
            fill="rgba(56,224,255,0.06)" stroke="rgba(127,240,255,0.6)" stroke-width="1"
            class="trace trace--draw" style="--len: 400; animation-delay: 0.8s;"/>
      <!-- 'V' monogram inside the core -->
      <text x="0" y="14" text-anchor="middle"
            font-family="Sora, Inter, sans-serif" font-size="56" font-weight="800"
            fill="rgba(127,240,255,0.8)">V</text>

      <!-- Pin pads on each edge -->
      <g fill="rgba(127,240,255,0.7)">
        <!-- top -->
        <circle cx="-140" cy="-180" r="3"/><circle cx="-100" cy="-180" r="3"/><circle cx="-60" cy="-180" r="3"/>
        <circle cx="-20" cy="-180" r="3"/><circle cx="20"  cy="-180" r="3"/><circle cx="60"  cy="-180" r="3"/>
        <circle cx="100" cy="-180" r="3"/><circle cx="140" cy="-180" r="3"/>
        <!-- bottom -->
        <circle cx="-140" cy="180" r="3"/><circle cx="-100" cy="180" r="3"/><circle cx="-60" cy="180" r="3"/>
        <circle cx="-20" cy="180" r="3"/><circle cx="20"  cy="180" r="3"/><circle cx="60"  cy="180" r="3"/>
        <circle cx="100" cy="180" r="3"/><circle cx="140" cy="180" r="3"/>
        <!-- left -->
        <circle cx="-180" cy="-140" r="3"/><circle cx="-180" cy="-100" r="3"/><circle cx="-180" cy="-60" r="3"/>
        <circle cx="-180" cy="-20" r="3"/><circle cx="-180" cy="20" r="3"/><circle cx="-180" cy="60" r="3"/>
        <circle cx="-180" cy="100" r="3"/><circle cx="-180" cy="140" r="3"/>
        <!-- right -->
        <circle cx="180" cy="-140" r="3"/><circle cx="180" cy="-100" r="3"/><circle cx="180" cy="-60" r="3"/>
        <circle cx="180" cy="-20" r="3"/><circle cx="180" cy="20" r="3"/><circle cx="180" cy="60" r="3"/>
        <circle cx="180" cy="100" r="3"/><circle cx="180" cy="140" r="3"/>
      </g>
    </g>

    <!-- Circuit traces fanning out from the die -->
    <g fill="none" stroke-linecap="round">
      <!-- left fan -->
      <path d="M780 310 L600 310 L600 200 L300 200" stroke="url(#traceGrad)" stroke-width="1.5"
            class="trace trace--draw trace--flow" style="--len: 700; animation-delay: 1.0s;"/>
      <path d="M780 390 L520 390 L520 460 L240 460" stroke="url(#traceGrad)" stroke-width="1.5"
            class="trace trace--draw trace--flow" style="--len: 800; animation-delay: 1.2s;"/>
      <path d="M780 510 L580 510 L580 660 L320 660" stroke="url(#traceGrad)" stroke-width="1.5"
            class="trace trace--draw trace--flow" style="--len: 760; animation-delay: 1.4s;"/>
      <path d="M780 470 L660 470 L660 800 L120 800" stroke="url(#traceGrad)" stroke-width="1.5"
            class="trace trace--draw trace--flow" style="--len: 1000; animation-delay: 1.6s;"/>
      <!-- right fan -->
      <path d="M1140 350 L1280 350 L1280 220 L1440 220" stroke="url(#traceGrad)" stroke-width="1.5"
            class="trace trace--draw trace--flow" style="--len: 620; animation-delay: 1.1s;"/>
      <path d="M1140 430 L1320 430 L1320 560 L1440 560" stroke="url(#traceGradOrange)" stroke-width="1.5"
            class="trace trace--draw trace--flow" style="--len: 580; animation-delay: 1.3s;"/>
      <path d="M1140 510 L1240 510 L1240 720 L1440 720" stroke="url(#traceGrad)" stroke-width="1.5"
            class="trace trace--draw trace--flow" style="--len: 760; animation-delay: 1.5s;"/>
      <!-- top fan -->
      <path d="M880 270 L880 130 L600 130 L600 30" stroke="url(#traceGrad)" stroke-width="1.5"
            class="trace trace--draw trace--flow" style="--len: 580; animation-delay: 1.7s;"/>
      <path d="M1040 270 L1040 90 L1200 90" stroke="url(#traceGradOrange)" stroke-width="1.5"
            class="trace trace--draw trace--flow" style="--len: 420; animation-delay: 1.9s;"/>
    </g>

    <!-- Floating nodes with pulse -->
    <g>
      <circle cx="300" cy="200" r="4" fill="#7ff0ff" class="node-pulse" style="animation-delay: 1.5s;"/>
      <circle cx="240" cy="460" r="4" fill="#7ff0ff" class="node-pulse" style="animation-delay: 1.7s;"/>
      <circle cx="320" cy="660" r="4" fill="#7ff0ff" class="node-pulse" style="animation-delay: 1.9s;"/>
      <circle cx="120" cy="800" r="4" fill="#7ff0ff" class="node-pulse" style="animation-delay: 2.1s;"/>
      <circle cx="1320" cy="220" r="4" fill="#7ff0ff" class="node-pulse" style="animation-delay: 1.6s;"/>
      <circle cx="1320" cy="560" r="4" fill="#ffb547" class="node-pulse" style="animation-delay: 1.8s;"/>
      <circle cx="1320" cy="720" r="4" fill="#7ff0ff" class="node-pulse" style="animation-delay: 2.0s;"/>
      <circle cx="600" cy="30"  r="4" fill="#7ff0ff" class="node-pulse" style="animation-delay: 2.2s;"/>
      <circle cx="1200" cy="90" r="4" fill="#ffb547" class="node-pulse" style="animation-delay: 2.4s;"/>
    </g>
  </svg>

  <!-- Decorative glow blobs -->
  <div class="absolute -top-32 -right-24 w-[520px] h-[520px] rounded-full bg-brand-500/30 blur-[120px]"></div>
  <div class="absolute -bottom-40 -left-32 w-[480px] h-[480px] rounded-full bg-accent-500/20 blur-[120px]"></div>
  <div class="absolute top-1/3 left-1/4 w-[300px] h-[300px] rounded-full bg-cyber-500/20 blur-[100px]"></div>
</div>

<style>
  .trace {
    stroke-dasharray: var(--len, 1000);
    stroke-dashoffset: var(--len, 1000);
  }
  .trace--draw {
    animation: trace-draw 1.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .trace--flow {
    /* Once draw finishes, switch to a slow ambient flow */
    animation:
      trace-draw 1.8s cubic-bezier(0.22, 1, 0.36, 1) forwards,
      trace-flow 6s linear infinite 2.5s;
  }
  .node-pulse {
    transform-origin: center;
    transform-box: fill-box;
    animation: node-pulse 2.4s ease-in-out infinite;
  }
</style>
