---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<section class="relative gradient-hero text-white overflow-hidden">
  <div class="absolute inset-0 grid-pattern opacity-30"></div>
  <div class="container-x relative py-20 md:py-28">
    {eyebrow && (
      <span class="inline-block uppercase tracking-[0.18em] text-xs font-bold text-accent-400 mb-4">
        {eyebrow}
      </span>
    )}
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-balance max-w-4xl leading-[1.1]">
      {title}
    </h1>
    {description && (
      <p class="mt-6 text-lg md:text-xl text-brand-100/85 max-w-2xl text-pretty">
        {description}
      </p>
    )}
    <slot />
  </div>
</section>
