---
import CircuitBackground from './CircuitBackground.astro';

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  variant?: 'default' | 'compact';
}

const { eyebrow, title, description, variant = 'default' } = Astro.props;
const pad = variant === 'compact' ? 'py-20 md:py-24' : 'py-28 md:py-36';
---

<section class="relative bg-night text-white overflow-hidden">
  <CircuitBackground />
  <div class="absolute inset-0 grid-pattern opacity-40"></div>
  <div class:list={['container-x relative', pad]}>
    {eyebrow && (
      <span class="eyebrow-dark mb-5" data-reveal>
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-cyber-400 animate-pulse"></span>
        {eyebrow}
      </span>
    )}
    <h1
      class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-balance max-w-4xl leading-[1.05]"
      data-reveal
      style="--reveal-delay: 80ms;"
    >
      {title}
    </h1>
    {description && (
      <p
        class="mt-6 text-lg md:text-xl text-white/75 max-w-2xl text-pretty"
        data-reveal
        style="--reveal-delay: 160ms;"
      >
        {description}
      </p>
    )}
    <slot />
  </div>
</section>
