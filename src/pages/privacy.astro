---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { site } from '../data/site';

const lastUpdated = '2026-05-01';
---

<BaseLayout title="Privacy Policy" description="How Versatile SOC India Pvt Ltd handles personal information.">
  <PageHero
    eyebrow="Legal"
    title="Privacy Policy"
    description={`How ${site.legalName} collects, uses and protects information shared with us.`}
  />

  <section class="container-x py-16 md:py-20">
    <article class="prose prose-lg max-w-3xl text-ink-700 leading-relaxed space-y-6">
      <p class="text-sm text-ink-500">Last updated: {new Date(lastUpdated).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' })}</p>

      <h2 class="text-2xl font-bold text-ink-900">Who we are</h2>
      <p>{site.legalName} ("Versatile SOC", "we", "us", "our") operates this website and offers engineering services to customers worldwide. This policy explains how we handle the personal information you provide through this site or in the course of doing business with us.</p>

      <h2 class="text-2xl font-bold text-ink-900">Information we collect</h2>
      <ul class="list-disc pl-6 space-y-2">
        <li>Contact details you provide via email (name, work email, company).</li>
        <li>Career application information you send us (CV, work history, references).</li>
        <li>Standard server logs and anonymous analytics about how this site is used.</li>
      </ul>

      <h2 class="text-2xl font-bold text-ink-900">How we use it</h2>
      <ul class="list-disc pl-6 space-y-2">
        <li>To respond to enquiries and run commercial conversations.</li>
        <li>To evaluate career applications and communicate with candidates.</li>
        <li>To operate, secure and improve the website.</li>
      </ul>
      <p>We do not sell personal information, and we do not share it with third parties except service providers acting under our instructions (for example, email delivery and hosting partners).</p>

      <h2 class="text-2xl font-bold text-ink-900">How we protect it</h2>
      <p>Our information security practices are aligned to ISO 27001. Access to personal information is limited to people who need it to do their work, and we use encryption in transit and at rest.</p>

      <h2 class="text-2xl font-bold text-ink-900">Your rights</h2>
      <p>You can ask us to access, correct or delete personal information we hold about you. Write to <a class="text-brand-700 underline" href={`mailto:${site.email}`}>{site.email}</a> and we will respond within a reasonable time.</p>

      <h2 class="text-2xl font-bold text-ink-900">Contact</h2>
      <p>Questions about this policy can be sent to <a class="text-brand-700 underline" href={`mailto:${site.email}`}>{site.email}</a>.</p>
    </article>
  </section>
</BaseLayout>
