---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ServiceCard from '../components/ServiceCard.astro';
import StatsBand from '../components/StatsBand.astro';
import CTASection from '../components/CTASection.astro';
import CircuitBackground from '../components/CircuitBackground.astro';
import AnimatedCounter from '../components/AnimatedCounter.astro';
import PartnerMarquee from '../components/PartnerMarquee.astro';
import { services } from '../data/services';
import { industries } from '../data/industries';
import { Icon } from 'astro-icon/components';

const differentiators = [
  {
    icon: 'lucide:scan-search',
    title: 'Concept to Completion',
    description: 'One accountable team across silicon, hardware and software — no hand-off gaps between disciplines.',
  },
  {
    icon: 'lucide:cpu',
    title: 'Advanced Node Expertise',
    description: 'Hands-on experience from mature nodes down to 5nm and 3nm, across logic, memory and mixed-signal designs.',
  },
  {
    icon: 'lucide:shield-check',
    title: 'Quality by Construction',
    description: 'ISO 9001 and ISO 27001 aligned processes, with security and safety lifecycles built into how we deliver.',
  },
  {
    icon: 'lucide:users',
    title: 'A True Engineering Partner',
    description: 'Outcome-based engagements, transparent reporting and senior engineers who stay with your program end-to-end.',
  },
];

const pillars = [
  { icon: 'lucide:gauge',     title: 'Faster Time-to-Market', description: 'Parallelized teams across silicon, embedded and apps compress critical-path schedules.' },
  { icon: 'lucide:cpu',       title: 'Deep Silicon DNA',      description: 'Engineers who have shipped real chips into volume, not just toy designs and lab demos.' },
  { icon: 'lucide:line-chart',title: 'Measurable Outcomes',   description: 'Engagements scoped around KPIs — coverage, PPA, schedule and quality — not just hours.' },
  { icon: 'lucide:lock',      title: 'IP-safe Collaboration', description: 'Secure infrastructure and audited workflows protect every customer artefact end-to-end.' },
];

// TODO[placeholder]: Replace these insight/blog cards with real published articles (or remove the
// section entirely from the homepage JSX below until the blog is live).
const insights = [
  {
    title: 'Designing for 3nm — what changes in your RTL hand-off',
    summary: 'Margin assumptions, multi-VT mixes and clocking strategies that survive when the node moves under you.',
    date: '2026-04-22',
    tag: 'Silicon',
  },
  {
    title: 'Edge AI on a $2 microcontroller — a practical playbook',
    summary: 'Quantization, calibration and runtime choices for vision workloads that need to run on Cortex-M class parts.',
    date: '2026-03-10',
    tag: 'AI',
  },
  {
    title: 'OTA done right — secure update pipelines for connected products',
    summary: 'Why most OTA designs fail audits, and the patterns we use to ship signed, recoverable updates at scale.',
    date: '2026-02-05',
    tag: 'Embedded',
  },
];

// TODO[placeholder]: These testimonials are fabricated samples with generic attribution.
// Replace each with a real quote + named author + company before publishing, or remove
// the testimonials section from the homepage JSX below.
const testimonials = [
  { quote: 'Versatile SOC ran our verification ramp like an internal team. Coverage closed on schedule and our first silicon came up clean.', author: 'VP Engineering', company: 'Fabless Networking Company' },
  { quote: 'They picked up an in-flight Linux BSP, untangled the upstream story and shipped us a kernel we can actually maintain.', author: 'Director of Platform', company: 'Industrial IoT OEM' },
  { quote: "We've worked with the big names. The difference here is senior engineers, every week, with answers — not just status.", author: 'CTO', company: 'AI Hardware Startup' },
];
---

<BaseLayout
  title="Silicon, Software & Systems — Engineered for What Comes Next"
  description="Versatile SOC India Pvt Ltd is a turnkey engineering services partner for semiconductor, embedded, AI and cloud product teams."
>
  <!-- ─────────── Hero ─────────── -->
  <section class="relative bg-night text-white overflow-hidden min-h-[100svh] flex items-center">
    <CircuitBackground />
    <div class="absolute inset-0 grid-pattern opacity-50"></div>

    <div class="container-x relative pt-32 pb-24 md:pt-40 md:pb-32 w-full">
      <div class="grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-7">
          <div data-reveal>
            <span class="eyebrow-dark">
              <span class="inline-block w-1.5 h-1.5 rounded-full bg-cyber-400 animate-pulse"></span>
              Semiconductor • Embedded • AI • Cloud
            </span>
          </div>

          <h1
            class="mt-7 font-display font-extrabold text-[2.7rem] sm:text-6xl lg:text-[5rem] xl:text-[5.5rem] leading-[0.95] tracking-tight text-balance"
            data-reveal style="--reveal-delay: 80ms;"
          >
            Silicon.<br>
            Software.<br>
            <span class="text-gradient-cyber text-glow">Systems.</span>
          </h1>

          <p
            class="mt-7 text-lg md:text-xl text-white/75 max-w-xl text-pretty"
            data-reveal style="--reveal-delay: 180ms;"
          >
            Versatile SOC India Pvt Ltd is the engineering partner behind ambitious chips, connected products and AI-powered platforms — one accountable team from concept to silicon, firmware, cloud and certification.
          </p>

          <div class="mt-9 flex flex-wrap gap-4" data-reveal style="--reveal-delay: 260ms;">
            <a href="/contact" class="btn btn-accent">
              Start a Conversation
              <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </a>
            <a href="/services" class="btn btn-glass">
              Explore Capabilities
            </a>
          </div>

          {/* TODO[placeholder]: Replace these hero stats with real, audited figures (tape-outs,
              engineers, node experience, delivery model) before going live. */}
          <div class="mt-14 grid grid-cols-2 sm:grid-cols-4 gap-x-6 gap-y-6 max-w-2xl" data-reveal style="--reveal-delay: 340ms;">
            <div>
              <p class="font-display font-extrabold text-3xl md:text-4xl text-gradient-cyber leading-none">
                <AnimatedCounter value={25} suffix="+" />
              </p>
              <p class="text-[11px] text-white/55 uppercase tracking-[0.18em] mt-2">Tape-outs</p>
            </div>
            <div>
              <p class="font-display font-extrabold text-3xl md:text-4xl text-gradient-cyber leading-none">
                <AnimatedCounter value={450} suffix="+" />
              </p>
              <p class="text-[11px] text-white/55 uppercase tracking-[0.18em] mt-2">Engineers</p>
            </div>
            <div>
              <p class="font-display font-extrabold text-3xl md:text-4xl text-gradient-cyber leading-none">5nm</p>
              <p class="text-[11px] text-white/55 uppercase tracking-[0.18em] mt-2">Node Experience</p>
            </div>
            <div>
              <p class="font-display font-extrabold text-3xl md:text-4xl text-gradient-cyber leading-none">24×7</p>
              <p class="text-[11px] text-white/55 uppercase tracking-[0.18em] mt-2">Delivery</p>
            </div>
          </div>
        </div>

        <!-- Hero side card: services preview floating over the circuit illustration -->
        <div class="lg:col-span-5 lg:pl-6" data-reveal style="--reveal-delay: 380ms;">
          <div class="relative float-slow">
            <div class="absolute -inset-6 bg-gradient-to-tr from-brand-500/30 via-cyber-400/20 to-accent-500/20 rounded-[2rem] blur-2xl"></div>
            <div class="relative glass p-6 md:p-7 shadow-2xl">
              <div class="flex items-center justify-between mb-5">
                <p class="text-xs uppercase tracking-[0.22em] text-cyber-300 font-bold">Where We Help</p>
                <span class="text-[10px] uppercase tracking-wider text-white/40">/ Capabilities</span>
              </div>
              <ul class="space-y-1">
                {services.map((s, i) => (
                  <li class="group">
                    <a
                      href={`/services/${s.slug}`}
                      class="flex items-center gap-4 -mx-2 px-2 py-2.5 rounded-xl hover:bg-white/5 transition"
                    >
                      <span class="w-10 h-10 rounded-lg inline-flex items-center justify-center bg-white/5 text-cyber-300 border border-white/10 group-hover:bg-cyber-500 group-hover:text-white group-hover:border-cyber-400 transition">
                        <Icon name={s.icon} class="w-5 h-5" />
                      </span>
                      <div class="flex-1 min-w-0">
                        <p class="font-semibold text-white truncate">{s.title}</p>
                        <p class="text-xs text-white/55 truncate">{s.tagline}</p>
                      </div>
                      <span class="text-white/30 group-hover:text-cyber-300 group-hover:translate-x-1 transition">
                        <Icon name="lucide:arrow-right" class="w-4 h-4" />
                      </span>
                    </a>
                    {i < services.length - 1 && <div class="border-t border-white/5"></div>}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- subtle scroll indicator -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 text-white/40 hidden md:flex flex-col items-center gap-2">
      <span class="text-[10px] uppercase tracking-[0.3em]">Scroll</span>
      <span class="w-px h-10 bg-gradient-to-b from-cyber-400/80 to-transparent"></span>
    </div>
  </section>

  <!-- ─────────── Partner Marquee ─────────── -->
  <PartnerMarquee />

  <!-- ─────────── Services ─────────── -->
  <section class="container-x py-24 md:py-32">
    <div data-reveal>
      <SectionHeading
        eyebrow="What We Do"
        title="A complete engineering stack, under one roof."
        description="We close the gap between silicon, embedded software and cloud — so you ship a coherent product, not five disconnected modules."
      />
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((s, i) => (
        <div data-reveal style={`--reveal-delay: ${(i % 3) * 80}ms`}>
          <ServiceCard
            title={s.title}
            description={s.short}
            href={`/services/${s.slug}`}
            icon={s.icon}
          />
        </div>
      ))}
    </div>
  </section>

  <!-- ─────────── What Sets Us Apart (dark band) ─────────── -->
  <section class="relative bg-night text-white py-24 md:py-32 overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-40"></div>
    <div class="absolute -top-32 right-0 w-[500px] h-[500px] rounded-full bg-brand-500/20 blur-[120px]"></div>
    <div class="absolute bottom-0 left-0 w-[420px] h-[420px] rounded-full bg-accent-500/15 blur-[120px]"></div>

    <div class="container-x relative">
      <div class="max-w-3xl mb-14" data-reveal>
        <span class="eyebrow-dark mb-4">
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-cyber-400 animate-pulse"></span>
          What Sets Us Apart
        </span>
        <h2 class="font-display font-extrabold text-3xl md:text-5xl text-balance leading-[1.05] mt-5">
          Senior engineers. <span class="text-gradient-cyber">Accountable outcomes.</span> Production track record.
        </h2>
        <p class="text-white/65 text-lg mt-5 text-pretty">
          The teams behind Versatile SOC have shipped real products into the field — from networking ASICs to smart cameras, from medical wearables to autonomous robots.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
        {differentiators.map((d, i) => (
          <div class="glass p-7 h-full" data-reveal style={`--reveal-delay: ${i * 80}ms`}>
            <div class="w-12 h-12 rounded-xl bg-cyber-500/10 text-cyber-300 border border-cyber-400/20 inline-flex items-center justify-center mb-5">
              <Icon name={d.icon} class="w-6 h-6" />
            </div>
            <h3 class="font-display font-bold text-lg text-white mb-2">{d.title}</h3>
            <p class="text-white/65 text-sm leading-relaxed">{d.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─────────── Mission / Vision / Values ─────────── -->
  <section class="container-x py-24 md:py-32">
    <div class="grid md:grid-cols-3 gap-6">
      <div class="relative overflow-hidden rounded-3xl bg-night text-white p-9" data-reveal>
        <CircuitBackground />
        <div class="absolute inset-0 grid-pattern opacity-40"></div>
        <div class="relative">
          <p class="text-xs uppercase tracking-[0.22em] text-cyber-300 font-bold mb-4">Mission</p>
          <h3 class="font-display text-2xl font-bold leading-tight">
            Make ambitious engineering reachable for product teams of every size.
          </h3>
          <p class="text-white/70 mt-5 text-sm leading-relaxed">
            We assemble senior, full-stack teams that take ownership from spec to ship — so our customers can focus on product, not co-ordination.
          </p>
        </div>
      </div>
      <div class="card-glow" data-reveal style="--reveal-delay: 80ms;">
        <p class="eyebrow mb-4">Vision</p>
        <h3 class="font-display text-2xl font-bold leading-tight text-ink-900">
          Become the default engineering partner for the next wave of intelligent hardware.
        </h3>
        <p class="text-ink-500 mt-5 text-sm leading-relaxed">
          From edge AI in everyday devices to silicon that powers the data centres behind them — we want our fingerprints on the products that define the decade.
        </p>
      </div>
      <div class="card-glow" data-reveal style="--reveal-delay: 160ms;">
        <p class="eyebrow mb-4">Values</p>
        <ul class="space-y-3 mt-2 text-sm text-ink-700">
          <li class="flex items-center gap-2"><Icon name="lucide:check" class="w-4 h-4 text-brand-600" /> Engineering rigour over theatre</li>
          <li class="flex items-center gap-2"><Icon name="lucide:check" class="w-4 h-4 text-brand-600" /> Customer outcomes over scope creep</li>
          <li class="flex items-center gap-2"><Icon name="lucide:check" class="w-4 h-4 text-brand-600" /> Transparency at every milestone</li>
          <li class="flex items-center gap-2"><Icon name="lucide:check" class="w-4 h-4 text-brand-600" /> Compound learning across teams</li>
          <li class="flex items-center gap-2"><Icon name="lucide:check" class="w-4 h-4 text-brand-600" /> Doing right by our people, first</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ─────────── Stats ─────────── -->
  <StatsBand />

  <!-- ─────────── Why Versatile SOC ─────────── -->
  <section class="container-x py-24 md:py-32">
    <div data-reveal>
      <SectionHeading
        eyebrow="Why Versatile SOC"
        title="Built for teams that need engineering muscle without the overhead."
        description="The right blend of senior leadership, deep specialists and process discipline — engaged the way you actually want to work."
      />
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
      {pillars.map((p, i) => (
        <div class="card-glow h-full" data-reveal style={`--reveal-delay: ${i * 80}ms`}>
          <div class="w-11 h-11 rounded-xl bg-accent-500/10 text-accent-600 inline-flex items-center justify-center mb-4">
            <Icon name={p.icon} class="w-5 h-5" />
          </div>
          <h3 class="font-display font-semibold text-lg text-ink-900 mb-1.5">{p.title}</h3>
          <p class="text-ink-500 text-sm leading-relaxed">{p.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ─────────── Industries ─────────── -->
  <section class="bg-slate-50 py-24 md:py-32">
    <div class="container-x">
      <div data-reveal>
        <SectionHeading
          eyebrow="Industries We Serve"
          title="Domain depth across the markets where hardware matters most."
          description="From safety-critical automotive silicon to consumer wearables and AI accelerators — our engineers bring context, not just resumes."
        />
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {industries.map((i, idx) => (
          <div
            class="group relative bg-white rounded-2xl p-6 border border-slate-100 hover:border-brand-200 hover:-translate-y-1 transition overflow-hidden"
            data-reveal style={`--reveal-delay: ${(idx % 4) * 70}ms`}
          >
            <div class="absolute -right-10 -top-10 w-32 h-32 rounded-full bg-brand-500/0 group-hover:bg-brand-500/10 blur-2xl transition"></div>
            <div class="relative">
              <div class="w-11 h-11 rounded-lg bg-brand-50 text-brand-600 inline-flex items-center justify-center mb-4 group-hover:bg-brand-600 group-hover:text-white transition">
                <Icon name={i.icon} class="w-5 h-5" />
              </div>
              <h3 class="font-semibold text-ink-900 mb-1">{i.name}</h3>
              <p class="text-ink-500 text-sm leading-relaxed">{i.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─────────── Testimonials ─────────── -->
  <section class="container-x py-24 md:py-32">
    <div data-reveal>
      <SectionHeading
        eyebrow="What Customers Say"
        title="Engineering partnerships that earn renewals."
      />
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {testimonials.map((t, i) => (
        <figure class="card-glow h-full flex flex-col" data-reveal style={`--reveal-delay: ${i * 80}ms`}>
          <Icon name="lucide:quote" class="w-8 h-8 text-brand-200 mb-4" />
          <blockquote class="text-ink-700 leading-relaxed text-base flex-1">"{t.quote}"</blockquote>
          <figcaption class="mt-6 pt-5 border-t border-slate-100">
            <p class="font-semibold text-ink-900">{t.author}</p>
            <p class="text-sm text-ink-500">{t.company}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </section>

  <!-- ─────────── Insights ─────────── -->
  <section class="relative bg-night text-white py-24 md:py-32 overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-40"></div>
    <div class="absolute -top-32 -right-20 w-[480px] h-[480px] rounded-full bg-brand-500/20 blur-[120px]"></div>

    <div class="container-x relative">
      <div class="flex flex-wrap items-end justify-between gap-6 mb-14" data-reveal>
        <div class="max-w-2xl">
          <span class="eyebrow-dark mb-4">
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-cyber-400 animate-pulse"></span>
            Insights
          </span>
          <h2 class="font-display font-extrabold text-3xl md:text-5xl leading-[1.05] mt-4 text-balance">
            Notes from the <span class="text-gradient-cyber">engineering floor</span>.
          </h2>
        </div>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {insights.map((i, idx) => (
          <article class="glass p-7 h-full flex flex-col group hover:border-cyber-400/30 transition" data-reveal style={`--reveal-delay: ${idx * 80}ms`}>
            <div class="flex items-center gap-2 text-xs">
              <span class="text-cyber-300 font-bold uppercase tracking-wider">{i.tag}</span>
              <span class="text-white/30">•</span>
              <time class="text-white/55">{new Date(i.date).toLocaleDateString('en-IN', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
            </div>
            <h3 class="mt-3 font-display font-bold text-lg leading-snug">{i.title}</h3>
            <p class="mt-3 text-white/65 text-sm leading-relaxed flex-1">{i.summary}</p>
            <span class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-cyber-300 group-hover:gap-3 transition-all">
              Read article
              <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
