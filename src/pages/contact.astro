---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { site } from '../data/site';
import { Icon } from 'astro-icon/components';

const mailtoBody = encodeURIComponent(
  `Hi Versatile SOC team,\n\nI'd like to discuss:\n\n[ Briefly describe your product, timeline and what you need help with ]\n\nName:\nCompany:\nRole:\n\nThanks.`
);
const mailtoSubject = encodeURIComponent('Enquiry — Versatile SOC');
const mailto = `mailto:${site.email}?subject=${mailtoSubject}&body=${mailtoBody}`;
---

<BaseLayout title="Contact" description={`Reach Versatile SOC India Pvt Ltd — email us at ${site.email}.`}>
  <PageHero
    eyebrow="Contact"
    title="Tell us what you're building."
    description="A senior engineer reads every inbound. Drop us a note and we'll come back within one business day with a real next step — not a generic deck."
  />

  <section class="container-x py-20 md:py-24">
    <div class="grid lg:grid-cols-12 gap-10 items-start">
      <!-- Email CTA card -->
      <div class="lg:col-span-7">
        <div class="relative overflow-hidden rounded-3xl gradient-hero text-white p-8 md:p-12">
          <div class="absolute inset-0 grid-pattern opacity-20"></div>
          <div class="relative">
            <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 text-[11px] font-bold uppercase tracking-[0.18em] text-accent-300 border border-white/15">
              <Icon name="lucide:mail" class="w-3.5 h-3.5" />
              Email is the fastest way
            </span>
            <h2 class="mt-5 font-display font-bold text-3xl md:text-4xl leading-tight text-balance">
              Write to us at
            </h2>
            <a
              href={mailto}
              class="mt-3 inline-block font-display font-bold text-3xl md:text-4xl text-accent-300 hover:text-accent-400 transition break-all"
            >
              {site.email}
            </a>
            <p class="mt-6 text-brand-100/85 max-w-xl">
              Share a few sentences about what you're working on — product, stage, timeline, and where you'd like help. We'll route your message to the right engineering lead and come back within one business day.
            </p>

            <div class="mt-8 flex flex-wrap gap-3">
              <a href={mailto} class="btn btn-accent">
                <Icon name="lucide:send" class="w-4 h-4" />
                Compose email
              </a>
              <button
                type="button"
                class="btn bg-white/10 text-white hover:bg-white/20 border border-white/20"
                data-copy={site.email}
              >
                <Icon name="lucide:copy" class="w-4 h-4" />
                <span data-copy-label>Copy address</span>
              </button>
            </div>
          </div>
        </div>

        <!-- Helpful checklist -->
        <div class="mt-6 bg-white rounded-2xl border border-slate-100 p-6 md:p-8">
          <h3 class="font-display font-bold text-lg text-ink-900">What to include in your email</h3>
          <p class="text-ink-500 text-sm mt-1">A little context helps us reply with something useful instead of a generic deck.</p>
          <ul class="mt-5 grid sm:grid-cols-2 gap-x-6 gap-y-3 text-sm text-ink-700">
            <li class="flex items-start gap-2"><Icon name="lucide:check-circle-2" class="w-4 h-4 text-brand-600 mt-0.5 flex-shrink-0" /> Your product and target market</li>
            <li class="flex items-start gap-2"><Icon name="lucide:check-circle-2" class="w-4 h-4 text-brand-600 mt-0.5 flex-shrink-0" /> Stage — concept, in-flight, or sustaining</li>
            <li class="flex items-start gap-2"><Icon name="lucide:check-circle-2" class="w-4 h-4 text-brand-600 mt-0.5 flex-shrink-0" /> Where you need help (silicon, embedded, AI, cloud)</li>
            <li class="flex items-start gap-2"><Icon name="lucide:check-circle-2" class="w-4 h-4 text-brand-600 mt-0.5 flex-shrink-0" /> Timeline and key milestones</li>
            <li class="flex items-start gap-2"><Icon name="lucide:check-circle-2" class="w-4 h-4 text-brand-600 mt-0.5 flex-shrink-0" /> Approximate team size you're looking for</li>
            <li class="flex items-start gap-2"><Icon name="lucide:check-circle-2" class="w-4 h-4 text-brand-600 mt-0.5 flex-shrink-0" /> Anything NDA-sensitive we should know upfront</li>
          </ul>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-5 space-y-5">
        <div class="rounded-2xl bg-white border border-slate-100 p-6 md:p-8">
          <h3 class="font-display font-bold text-lg text-ink-900">Reach Us</h3>
          <ul class="mt-5 space-y-5 text-sm">
            <li class="flex items-start gap-3">
              <span class="w-9 h-9 rounded-lg bg-brand-50 text-brand-600 inline-flex items-center justify-center flex-shrink-0">
                <Icon name="lucide:mail" class="w-4 h-4" />
              </span>
              <div>
                <p class="text-xs text-ink-500 uppercase tracking-wider">Email</p>
                <a class="font-semibold text-ink-900 hover:text-brand-700 transition" href={`mailto:${site.email}`}>{site.email}</a>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-9 h-9 rounded-lg bg-brand-50 text-brand-600 inline-flex items-center justify-center flex-shrink-0">
                <Icon name="lucide:map-pin" class="w-4 h-4" />
              </span>
              <div>
                <p class="text-xs text-ink-500 uppercase tracking-wider">Office</p>
                <p class="font-semibold text-ink-900 leading-snug">{site.address.line1}<br>{site.address.line2}<br>{site.address.line3}</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-9 h-9 rounded-lg bg-brand-50 text-brand-600 inline-flex items-center justify-center flex-shrink-0">
                <Icon name="lucide:clock" class="w-4 h-4" />
              </span>
              <div>
                <p class="text-xs text-ink-500 uppercase tracking-wider">Response time</p>
                <p class="font-semibold text-ink-900">Within 1 business day</p>
              </div>
            </li>
          </ul>
        </div>

        <div class="rounded-2xl bg-white border border-slate-100 p-6">
          <h3 class="font-display font-bold text-lg text-ink-900">Other channels</h3>
          <ul class="mt-4 space-y-3 text-sm">
            <li class="flex items-center gap-2 text-ink-700">
              <Icon name="lucide:newspaper" class="w-4 h-4 text-brand-600" />
              Press: <a class="font-semibold text-brand-700 hover:underline" href={`mailto:${site.email}`}>{site.email}</a>
            </li>
            <li class="flex items-center gap-2 text-ink-700">
              <Icon name="lucide:linkedin" class="w-4 h-4 text-brand-600" />
              <a class="font-semibold text-brand-700 hover:underline" href={site.social.linkedin}>Follow us on LinkedIn</a>
            </li>
          </ul>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<script>
  const btn = document.querySelector<HTMLButtonElement>('[data-copy]');
  const label = document.querySelector<HTMLElement>('[data-copy-label]');
  btn?.addEventListener('click', async () => {
    const value = btn.dataset.copy;
    if (!value || !label) return;
    try {
      await navigator.clipboard.writeText(value);
      const original = label.textContent ?? '';
      label.textContent = 'Copied';
      setTimeout(() => { label.textContent = original; }, 1500);
    } catch {
      label.textContent = 'Press Cmd/Ctrl+C';
    }
  });
</script>
